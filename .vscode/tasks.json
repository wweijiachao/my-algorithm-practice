{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "WSL-G++编译", // 任务名称
            "command": "/usr/bin/g++", // 编译器的绝对路径
            "args": [
                "-fdiagnostics-color=always",
                "-g", // 生成调试信息，不加这个没法断点调试
                "${file}", // 当前打开的源文件
                "-Wall",
                "-O0",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}" // 生成的可执行文件名
            ],
            "options": {
                "cwd": "${fileDirname}" // 在源文件所在目录运行命令
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true // 设置为默认编译任务
            },
            "detail": "研究生级别的基础C++编译配置"
        }
    ]
}